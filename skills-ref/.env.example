# =============================================================================
# AgentSkills Enterprise Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# Environment variables override defaults from config files
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Selection
# -----------------------------------------------------------------------------
# Options: development, testing, staging, production
AGENTSKILLS_ENV=development

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Enable/disable authentication (default: true in non-dev)
AGENTSKILLS_AUTH__ENABLED=true

# JWT secret key - REQUIRED for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTSKILLS_AUTH__JWT_SECRET=your-super-secret-key-change-this

# JWT algorithm (default: HS256)
AGENTSKILLS_AUTH__JWT_ALGORITHM=HS256

# Access token TTL in seconds (default: 3600 = 1 hour)
AGENTSKILLS_AUTH__ACCESS_TOKEN_TTL_SECONDS=3600

# Refresh token TTL in seconds (default: 604800 = 7 days)
AGENTSKILLS_AUTH__REFRESH_TOKEN_TTL_SECONDS=604800

# API key authentication
AGENTSKILLS_AUTH__API_KEY_ENABLED=true
AGENTSKILLS_AUTH__API_KEY_HEADER=X-API-Key

# Require HTTPS (default: true in production)
AGENTSKILLS_AUTH__REQUIRE_HTTPS=false

# Comma-separated list of allowed JWT issuers
# AGENTSKILLS_AUTH__ALLOWED_ISSUERS=["https://auth.example.com"]

# -----------------------------------------------------------------------------
# RBAC (Role-Based Access Control)
# -----------------------------------------------------------------------------
# Enable/disable RBAC (default: true)
AGENTSKILLS_RBAC__ENABLED=true

# Default role for new users (default: viewer)
AGENTSKILLS_RBAC__DEFAULT_ROLE=viewer

# Comma-separated list of admin user IDs
# AGENTSKILLS_RBAC__ADMIN_USERS=["user-123", "user-456"]

# Path to custom roles file (JSON/YAML)
# AGENTSKILLS_RBAC__CUSTOM_ROLES_FILE=/path/to/roles.yaml

# Path to policy file (JSON/YAML)
# AGENTSKILLS_RBAC__POLICY_FILE=/path/to/policy.yaml

# Permission cache TTL in seconds (default: 300)
AGENTSKILLS_RBAC__CACHE_TTL_SECONDS=300

# Inherit permissions from parent roles (default: true)
AGENTSKILLS_RBAC__INHERIT_PERMISSIONS=true

# -----------------------------------------------------------------------------
# Secrets Management
# -----------------------------------------------------------------------------
# Backend type: env, aws, vault
AGENTSKILLS_SECRETS__BACKEND=env

# Enable secret caching (default: true)
AGENTSKILLS_SECRETS__CACHE_ENABLED=true

# Cache TTL in seconds (default: 300)
AGENTSKILLS_SECRETS__CACHE_TTL_SECONDS=300

# Mask secrets in logs (default: true)
AGENTSKILLS_SECRETS__MASK_IN_LOGS=true

# Audit secret access (default: true in production)
AGENTSKILLS_SECRETS__AUDIT_ACCESS=false

# AWS Secrets Manager settings
AGENTSKILLS_SECRETS__AWS_REGION=us-east-1
AGENTSKILLS_SECRETS__AWS_SECRET_PREFIX=agentskills/

# HashiCorp Vault settings
# AGENTSKILLS_SECRETS__VAULT_ADDR=https://vault.example.com:8200
# AGENTSKILLS_SECRETS__VAULT_TOKEN=hvs.xxx
AGENTSKILLS_SECRETS__VAULT_MOUNT=secret

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: debug, info, warning, error, critical
AGENTSKILLS_LOGGING__LEVEL=info

# Log format: json, text
AGENTSKILLS_LOGGING__FORMAT=json

# Include context in logs (default: true)
AGENTSKILLS_LOGGING__INCLUDE_CONTEXT=true

# Include trace ID in logs (default: true)
AGENTSKILLS_LOGGING__INCLUDE_TRACE_ID=true

# Mask sensitive fields (default: true)
AGENTSKILLS_LOGGING__MASK_SENSITIVE=true

# Log output file (optional, defaults to stdout)
# AGENTSKILLS_LOGGING__OUTPUT_FILE=/var/log/agentskills/app.log

# Maximum message length before truncation
AGENTSKILLS_LOGGING__MAX_MESSAGE_LENGTH=10000

# -----------------------------------------------------------------------------
# Distributed Tracing
# -----------------------------------------------------------------------------
# Enable tracing (default: true)
AGENTSKILLS_TRACING__ENABLED=true

# Service name for traces
AGENTSKILLS_TRACING__SERVICE_NAME=agentskills

# Sample rate (0.0 to 1.0, default: 1.0 in dev, 0.1 in prod)
AGENTSKILLS_TRACING__SAMPLE_RATE=1.0

# Exporter type: console, jaeger, otlp
AGENTSKILLS_TRACING__EXPORTER=console

# Jaeger settings
# AGENTSKILLS_TRACING__JAEGER_ENDPOINT=http://jaeger:14268/api/traces
AGENTSKILLS_TRACING__JAEGER_AGENT_HOST=localhost
AGENTSKILLS_TRACING__JAEGER_AGENT_PORT=6831

# OTLP settings (OpenTelemetry)
# AGENTSKILLS_TRACING__OTLP_ENDPOINT=http://otel-collector:4317

# Propagate trace context to downstream services
AGENTSKILLS_TRACING__PROPAGATE_CONTEXT=true

# -----------------------------------------------------------------------------
# Execution Environment
# -----------------------------------------------------------------------------
# Auto-detect execution environment (default: true)
AGENTSKILLS_EXECUTION__AUTO_DETECT_ENVIRONMENT=true

# Default skill timeout in milliseconds
AGENTSKILLS_EXECUTION__DEFAULT_TIMEOUT_MS=30000

# Maximum allowed timeout in milliseconds
AGENTSKILLS_EXECUTION__MAX_TIMEOUT_MS=300000

# Maximum retry attempts
AGENTSKILLS_EXECUTION__MAX_RETRIES=3

# Retry backoff base (exponential)
AGENTSKILLS_EXECUTION__RETRY_BACKOFF_BASE=2.0

# Enable sandboxing (default: true in production)
AGENTSKILLS_EXECUTION__SANDBOX_ENABLED=false

# Allowed environments (JSON array)
# AGENTSKILLS_EXECUTION__ALLOWED_ENVIRONMENTS=["local", "docker", "cloud"]

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Skill composition (combining skills into chains)
AGENTSKILLS_FEATURES__ENABLE_SKILL_COMPOSITION=true

# Skill versioning (semantic versioning support)
AGENTSKILLS_FEATURES__ENABLE_SKILL_VERSIONING=true

# Lessons system (learning from skill outcomes)
AGENTSKILLS_FEATURES__ENABLE_LESSONS_SYSTEM=true

# Higher-order skills (skills that generate skills)
AGENTSKILLS_FEATURES__ENABLE_HIGHER_ORDER_SKILLS=true

# Distributed execution (across multiple workers)
AGENTSKILLS_FEATURES__ENABLE_DISTRIBUTED_EXECUTION=false

# Cost tracking (token/API usage tracking)
AGENTSKILLS_FEATURES__ENABLE_COST_TRACKING=true

# Audit logging (detailed operation logging)
AGENTSKILLS_FEATURES__ENABLE_AUDIT_LOGGING=true

# -----------------------------------------------------------------------------
# API Keys (for skill dependencies)
# -----------------------------------------------------------------------------
# Store API keys here or in secrets manager
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# PERPLEXITY_API_KEY=pplx-xxx

# -----------------------------------------------------------------------------
# Database (if using persistent storage)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentskills

# -----------------------------------------------------------------------------
# Redis (if using distributed caching/locking)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
